<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PARA Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0d1117; --surface: #161b22; --border: #21262d;
    --border2: #30363d; --text: #e6edf3; --muted: #8b949e;
    --dim: #484f58; --green: #238636; --blue: #1f6feb;
    --red: #ef4444; --amber: #f59e0b; --purple: #8b5cf6;
    --teal: #10b981; --orange: #f97316;
  }
  html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'Outfit', sans-serif; }
  button { cursor: pointer; font-family: 'Outfit', sans-serif; }
  input, select, textarea { font-family: 'DM Mono', monospace; }
  ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

#app { display: flex; height: 100vh; overflow: hidden; }

/* ── Sidebar ── */
#sidebar {
width: 220px; flex-shrink: 0; border-right: 1px solid var(–border);
display: flex; flex-direction: column; padding: 18px 10px; gap: 2px; overflow-y: auto;
}
.sidebar-logo { font-weight: 700; font-size: 20px; padding: 4px 12px 16px; letter-spacing: -0.03em; color: var(–text); }
.sidebar-section { color: var(–dim); font-family: ‘DM Mono’, monospace; font-size: 10px;
letter-spacing: 0.1em; text-transform: uppercase; padding: 10px 12px 4px; }
.nav-btn {
display: flex; align-items: center; gap: 9px; width: 100%; padding: 8px 12px;
border-radius: 7px; border: none; background: transparent; color: var(–muted);
font-size: 13.5px; font-weight: 400; text-align: left; transition: all 0.12s;
}
.nav-btn:hover { background: var(–surface); color: var(–text); }
.nav-btn.active { background: var(–surface); color: var(–text); font-weight: 600; }
.sidebar-stats { border-top: 1px solid var(–border); padding-top: 12px; margin-top: auto; }
.stat-row { display: flex; justify-content: space-between; padding: 3px 12px;
font-family: ‘DM Mono’, monospace; font-size: 12px; color: var(–dim); }
.stat-val { color: var(–muted); }
.stat-val.danger { color: var(–red); }

/* ── Main ── */
#main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
#header { padding: 20px 28px 0; display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
#header h1 { font-size: 26px; font-weight: 700; letter-spacing: -0.03em; flex: 1; }
#header .sub { color: var(–dim); font-family: ‘DM Mono’, monospace; font-size: 12px; margin-top: 2px; }
#search { background: var(–surface); border: 1px solid var(–border2); border-radius: 8px;
color: var(–text); padding: 8px 14px; font-size: 13px; outline: none; width: 200px; }
#search::placeholder { color: var(–dim); }
.btn-primary { background: var(–green); border: none; color: #fff; border-radius: 7px;
padding: 9px 18px; font-weight: 600; font-size: 13.5px; white-space: nowrap; }
.btn-primary:hover { filter: brightness(1.15); }
.btn-blue { background: var(–blue); }

#filters { padding: 14px 28px 0; display: flex; gap: 7px; flex-wrap: wrap; flex-shrink: 0; }
.chip { padding: 4px 12px; border-radius: 20px; border: 1px solid var(–border2);
background: transparent; color: var(–muted); font-size: 12px; font-family: ‘DM Mono’, monospace; transition: all 0.12s; }
.chip:hover { border-color: var(–blue); color: #58a6ff; }
.chip.active { border-color: var(–blue); background: #1f6feb22; color: #58a6ff; }
.chip-sep { width: 1px; background: var(–border); margin: 0 4px; }

#content { flex: 1; padding: 18px 28px; overflow-y: auto; }

/* ── Task Row ── */
.task-row {
display: flex; align-items: center; gap: 10px; padding: 10px 14px;
border-radius: 8px; background: var(–bg); border: 1px solid var(–border);
margin-bottom: 6px; transition: border-color 0.12s;
}
.task-row:hover { border-color: var(–border2); }
.task-row.done { opacity: 0.5; }
.check-btn { width: 18px; height: 18px; border-radius: 4px; border: 2px solid var(–border2);
background: transparent; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
transition: all 0.12s; }
.check-btn.checked { background: var(–teal); border-color: var(–teal); color: #fff; font-size: 10px; }
.task-title { flex: 1; font-size: 14px; font-weight: 500; white-space: nowrap;
overflow: hidden; text-overflow: ellipsis; }
.task-row.done .task-title { text-decoration: line-through; color: var(–dim); }
.task-meta { font-family: ‘DM Mono’, monospace; font-size: 11px; color: var(–dim); margin-top: 2px; }
.badge { font-family: ‘DM Mono’, monospace; font-size: 11px; flex-shrink: 0; white-space: nowrap; }
.icon-btn { background: none; border: none; color: var(–dim); font-size: 13px; padding: 0 3px; }
.icon-btn:hover { color: var(–muted); }

/* ── Section header ── */
.section-hdr { color: var(–muted); font-family: ‘DM Mono’, monospace; font-size: 11px;
letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; }
.section-hdr.danger { color: var(–red); }
.section-block { margin-bottom: 24px; }

/* ── Quick capture ── */
#quick-cap { background: var(–surface); border: 1px dashed var(–border2); border-radius: 10px;
padding: 12px 16px; display: flex; gap: 10px; align-items: center; margin-top: 20px; }
#quick-input { flex: 1; background: transparent; border: none; outline: none;
color: var(–text); font-family: ‘Outfit’, sans-serif; font-size: 14px; }
#quick-input::placeholder { color: var(–dim); }
#quick-add { background: none; border: none; color: var(–green); font-weight: 600; font-size: 13px; }

/* ── Notes ── */
#notes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
.note-card { background: var(–surface); border: 1px solid var(–border); border-radius: 10px;
padding: 16px; display: flex; flex-direction: column; gap: 8px; }
.note-title { font-weight: 600; font-size: 15px; }
.note-meta { font-family: ‘DM Mono’, monospace; font-size: 11px; color: var(–dim); }
.note-body { font-family: ‘DM Mono’, monospace; font-size: 13px; color: var(–muted);
white-space: pre-wrap; max-height: 100px; overflow: hidden; line-height: 1.6; }
.note-actions { display: flex; gap: 4px; justify-content: flex-end; }

/* ── Empty ── */
.empty { color: var(–dim); font-size: 14px; padding: 24px 0; }

/* ── Modal ── */
#modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 100;
display: none; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
#modal-overlay.open { display: flex; }
#modal-box { background: var(–surface); border: 1px solid var(–border2); border-radius: 12px;
padding: 26px; width: 90vw; max-width: 520px; max-height: 88vh; overflow-y: auto;
box-shadow: 0 24px 64px rgba(0,0,0,0.6); }
.modal-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.modal-title { font-size: 17px; font-weight: 600; }
.modal-close { background: none; border: none; color: var(–dim); font-size: 22px; line-height: 1; }
.form-group { margin-bottom: 14px; }
.form-label { color: var(–muted); font-size: 11px; font-family: ‘DM Mono’, monospace;
letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 5px; display: block; }
.form-input { width: 100%; background: var(–bg); border: 1px solid var(–border2);
border-radius: 6px; color: var(–text); padding: 8px 12px; font-size: 13.5px;
font-family: ‘DM Mono’, monospace; outline: none; }
.form-input:focus { border-color: var(–blue); }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
textarea.form-input { min-height: 80px; resize: vertical; }
.form-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 6px; }
.btn-cancel { background: none; border: 1px solid var(–border2); color: var(–muted);
border-radius: 6px; padding: 8px 18px; font-size: 13.5px; }
.btn-save { background: var(–green); border: none; color: #fff; border-radius: 6px;
padding: 8px 18px; font-weight: 600; font-size: 13.5px; }
.btn-save.blue { background: var(–blue); }

/* animations */
@keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }
.task-row, .note-card { animation: fadeIn 0.18s ease both; }
</style>

</head>
