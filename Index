<script>
// ── Data ──────────────────────────────────────────────────────────────────────
const STATUSES = ["Not Started","Waiting / Blocked","Someday / Maybe","Done"];
const PRIORITIES = ["High","Medium","Low"];
const PARA_SECTIONS = ["Projects","Areas","Resources","Archive"];
const STATUS_COLOR = {"Not Started":"#6b7280","Waiting / Blocked":"#f59e0b","Someday / Maybe":"#8b5cf6","Done":"#10b981"};
const PRI_COLOR = {"High":"#ef4444","Medium":"#f97316","Low":"#3b82f6"};

const DEFAULT = {
  tasks: [
    {id:1,title:"Set up dashboard",project:"Projects",status:"Done",priority:"High",due:"",notes:"",area:"Work"},
    {id:2,title:"Review Q2 roadmap",project:"Projects",status:"Not Started",priority:"High",due:"",notes:"",area:"Work"},
    {id:3,title:"Organize reference folder",project:"Resources",status:"Someday / Maybe",priority:"Low",due:"",notes:"",area:"Personal"},
  ],
  notes: [
    {id:1,title:"PARA Overview",content:"Projects → active goals\nAreas → ongoing responsibilities\nResources → reference material\nArchive → inactive items",para:"Resources",updated:new Date().toISOString()},
  ],
  areas: ["Work","Personal","Health","Finance","Learning"],
};

function load() {
  try { const d = localStorage.getItem("para-v1"); return d ? JSON.parse(d) : JSON.parse(JSON.stringify(DEFAULT)); }
  catch { return JSON.parse(JSON.stringify(DEFAULT)); }
}
function save() { try { localStorage.setItem("para-v1",JSON.stringify(db)); } catch{} }

let db = load();
let state = { view:"today", para:"Projects", filterStatus:"All", filterPriority:"All", search:"", editId:null, editType:null };

function uid() { return Date.now() + Math.random(); }
function todayISO() { return new Date().toISOString().split("T")[0]; }
function fmtDate(iso) { if(!iso) return ""; return new Date(iso).toLocaleDateString("en-US",{month:"short",day:"numeric"}); }

// ── Render ────────────────────────────────────────────────────────────────────
function render() {
  renderHeader();
  renderFilters();
  renderContent();
  renderStats();
  bindNav();
}

function renderHeader() {
  const titles = {today:"Today",tasks:"All Tasks",notes:"Notes",para:state.para};
  document.getElementById("view-title").textContent = titles[state.view];
  document.getElementById("view-date").textContent = new Date().toLocaleDateString("en-US",{weekday:"long",month:"long",day:"numeric"});
  document.getElementById("new-btn").textContent = state.view === "notes" ? "+ New Note" : "+ New Task";
}

function renderFilters() {
  const f = document.getElementById("filters");
  if (state.view === "notes") { f.innerHTML = ""; return; }
  let html = "";
  const chip = (val, active, group, label) =>
    `<button class="chip ${active?"active":""}" data-fgroup="${group}" data-fval="${val}">${label}</button>`;
  html += chip("All", state.filterStatus==="All","status","All Status");
  STATUSES.forEach(s => html += chip(s, state.filterStatus===s,"status",s));
  html += `<div class="chip-sep"></div>`;
  html += chip("All", state.filterPriority==="All","priority","All Priority");
  PRIORITIES.forEach(p => html += chip(p, state.filterPriority===p,"priority",p));
  f.innerHTML = html;
  f.querySelectorAll(".chip[data-fgroup]").forEach(btn => {
    btn.addEventListener("click", () => {
      if (btn.dataset.fgroup === "status") state.filterStatus = btn.dataset.fval;
      else state.filterPriority = btn.dataset.fval;
      render();
    });
  });
}

function filterTasks() {
  const q = state.search.toLowerCase();
  return db.tasks.filter(t => {
    if (state.filterStatus !== "All" && t.status !== state.filterStatus) return false;
    if (state.filterPriority !== "All" && t.priority !== state.filterPriority) return false;
    if (state.view === "para" && t.project !== state.para) return false;
    if (q && !t.title.toLowerCase().includes(q)) return false;
    return true;
  });
}

function taskRowHTML(t) {
  const done = t.status === "Done";
  const meta = [t.project, t.area, t.due ? fmtDate(t.due) : ""].filter(Boolean).join(" · ");
  return `<div class="task-row ${done?"done":""}" data-id="${t.id}">
    <button class="check-btn ${done?"checked":""}" data-toggle="${t.id}">${done?"✓":""}</button>
    <div style="flex:1;min-width:0">
      <div class="task-title">${esc(t.title)}</div>
      <div class="task-meta">${esc(meta)}</div>
    </div>
    <span class="badge" style="color:${STATUS_COLOR[t.status]}">${t.status}</span>
    <span class="badge" style="color:${PRI_COLOR[t.priority]};margin-left:6px">${t.priority}</span>
    <button class="icon-btn" data-edit="${t.id}">✏️</button>
    <button class="icon-btn" data-del="${t.id}">🗑</button>
  </div>`;
}

function renderContent() {
  const el = document.getElementById("content");
  const q = state.search.toLowerCase();

  if (state.view === "today") {
    const today = todayISO();
    const overdue = db.tasks.filter(t => t.status!=="Done" && t.due && t.due < today);
    const focus = db.tasks.filter(t => t.status!=="Done" && t.status!=="Someday / Maybe" && (!t.due || t.due === today));
    let html = "";
    if (overdue.length) {
      html += `<div class="section-block"><div class="section-hdr danger">⚠ Overdue (${overdue.length})</div>`;
      html += overdue.map(taskRowHTML).join("") + "</div>";
    }
    html += `<div class="section-block"><div class="section-hdr">Focus (${focus.length} tasks)</div>`;
    html += focus.length ? focus.map(taskRowHTML).join("") : `<div class="empty">Nothing due today — add a task below.</div>`;
    html += `</div>
    <div id="quick-cap">
      <span style="color:var(--dim);font-size:16px">⚡</span>
      <input id="quick-input" type="text" placeholder="Quick capture — type a task and hit Enter" />
      <button id="quick-add" style="display:none">Add →</button>
    </div>`;
    el.innerHTML = html;
    const qi = document.getElementById("quick-input");
    const qa = document.getElementById("quick-add");
    qi.addEventListener("input", () => qa.style.display = qi.value.trim() ? "block" : "none");
    qi.addEventListener("keydown", e => e.key === "Enter" && quickAdd());
    qa.addEventListener("click", quickAdd);
    function quickAdd() {
      const v = qi.value.trim(); if (!v) return;
      db.tasks.unshift({id:uid(),title:v,project:"Projects",status:"Not Started",priority:"Medium",due:"",notes:"",area:db.areas[0]||"Work"});
      save(); qi.value = ""; qa.style.display = "none"; render();
    }
  }

  else if (state.view === "tasks" || state.view === "para") {
    const tasks = filterTasks();
    el.innerHTML = tasks.length ? tasks.map(taskRowHTML).join("") : `<div class="empty">No tasks match your filters.</div>`;
  }

  else if (state.view === "notes") {
    const notes = db.notes.filter(n => !q || n.title.toLowerCase().includes(q) || n.content.toLowerCase().includes(q));
    if (!notes.length) { el.innerHTML = `<div class="empty">No notes yet — create one above.</div>`; return; }
    el.innerHTML = `<div id="notes-grid">${notes.map(n => `
      <div class="note-card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div class="note-title">${esc(n.title)}</div>
          <div class="note-actions">
            <button class="icon-btn" data-edit-note="${n.id}">✏️</button>
            <button class="icon-btn" data-del-note="${n.id}">🗑</button>
          </div>
        </div>
        <div class="note-meta">${n.para} · ${fmtDate(n.updated)}</div>
        <div class="note-body">${esc(n.content)}</div>
      </div>`).join("")}</div>`;
    el.querySelectorAll("[data-edit-note]").forEach(b => b.addEventListener("click", () => openNoteModal(b.dataset.editNote)));
    el.querySelectorAll("[data-del-note]").forEach(b => b.addEventListener("click", () => { db.notes = db.notes.filter(n=>String(n.id)!==b.dataset.delNote); save(); render(); }));
  }

  // Task row events
  el.querySelectorAll("[data-toggle]").forEach(b => b.addEventListener("click", () => {
    const t = db.tasks.find(t=>String(t.id)===b.dataset.toggle);
    if (t) { t.status = t.status==="Done" ? "Not Started" : "Done"; save(); render(); }
  }));
  el.querySelectorAll("[data-edit]").forEach(b => b.addEventListener("click", () => openTaskModal(b.dataset.edit)));
  el.querySelectorAll("[data-del]").forEach(b => b.addEventListener("click", () => { db.tasks = db.tasks.filter(t=>String(t.id)!==b.dataset.del); save(); render(); }));
}

function renderStats() {
  const today = todayISO();
  const active = db.tasks.filter(t=>t.status!=="Done"&&t.status!=="Someday / Maybe").length;
  const overdue = db.tasks.filter(t=>t.status!=="Done"&&t.due&&t.due<today).length;
  document.getElementById("stat-active").textContent = active;
  const ov = document.getElementById("stat-overdue"); ov.textContent = overdue;
  ov.className = "stat-val" + (overdue > 0 ? " danger" : "");
  document.getElementById("stat-notes").textContent = db.notes.length;
}

function bindNav() {
  document.querySelectorAll(".nav-btn").forEach(btn => {
    btn.classList.toggle("active", btn.dataset.view === state.view && (!btn.dataset.para || btn.dataset.para === state.para));
    btn.addEventListener("click", () => {
      state.view = btn.dataset.view;
      if (btn.dataset.para) state.para = btn.dataset.para;
      render();
    });
  });
}

// ── Modals ────────────────────────────────────────────────────────────────────
function openTaskModal(id) {
  const t = id ? db.tasks.find(t=>String(t.id)===String(id)) : null;
  const v = t || {title:"",project:"Projects",status:"Not Started",priority:"Medium",due:"",notes:"",area:db.areas[0]||"Work"};
  document.getElementById("modal-title").textContent = t ? "Edit Task" : "New Task";
  document.getElementById("modal-body").innerHTML = `
    <div class="form-group"><label class="form-label">Task title</label>
      <input class="form-input" id="f-title" value="${esc(v.title)}" placeholder="What needs to be done?" /></div>
    <div class="form-grid">
      <div class="form-group"><label class="form-label">PARA section</label>
        <select class="form-input" id="f-project">${PARA_SECTIONS.map(p=>`<option ${v.project===p?"selected":""}>${p}</option>`).join("")}</select></div>
      <div class="form-group"><label class="form-label">Area</label>
        <select class="form-input" id="f-area">${db.areas.map(a=>`<option ${v.area===a?"selected":""}>${a}</option>`).join("")}</select></div>
      <div class="form-group"><label class="form-label">Status</label>
        <select class="form-input" id="f-status">${STATUSES.map(s=>`<option ${v.status===s?"selected":""}>${s}</option>`).join("")}</select></div>
      <div class="form-group"><label class="form-label">Priority</label>
        <select class="form-input" id="f-priority">${PRIORITIES.map(p=>`<option ${v.priority===p?"selected":""}>${p}</option>`).join("")}</select></div>
      <div class="form-group"><label class="form-label">Due date</label>
        <input class="form-input" type="date" id="f-due" value="${v.due||""}" /></div>
    </div>
    <div class="form-group"><label class="form-label">Notes</label>
      <textarea class="form-input" id="f-notes" placeholder="Any context...">${esc(v.notes)}</textarea></div>

```
