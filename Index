function openNoteModal(id) {
const n = id ? db.notes.find(n=>String(n.id)===String(id)) : null;
const v = n || {title:””,content:””,para:“Resources”};
document.getElementById(“modal-title”).textContent = n ? “Edit Note” : “New Note”;
document.getElementById(“modal-body”).innerHTML = ` <div class="form-group"><input class="form-input" id="f-ntitle" value="${esc(v.title)}" placeholder="Note title" /></div> <div class="form-group"> <select class="form-input" id="f-npara">${PARA_SECTIONS.map(p=>`<option ${v.para===p?“selected”:””}>${p}</option>`).join("")}</select></div> <div class="form-group"><textarea class="form-input" id="f-ncontent" style="min-height:160px" placeholder="Write anything...">${esc(v.content)}</textarea></div> <div class="form-actions"> <button class="btn-cancel" id="modal-cancel">Cancel</button> <button class="btn-save blue" id="modal-save">Save Note</button> </div>`;
document.getElementById(“modal-overlay”).classList.add(“open”);
document.getElementById(“f-ntitle”).focus();
document.getElementById(“modal-cancel”).addEventListener(“click”, closeModal);
document.getElementById(“modal-save”).addEventListener(“click”, () => {
const title = document.getElementById(“f-ntitle”).value.trim();
if (!title) return;
const updated = { id: n ? n.id : uid(), title, content: document.getElementById(“f-ncontent”).value, para: document.getElementById(“f-npara”).value, updated: new Date().toISOString() };
if (n) { const i = db.notes.findIndex(x=>x.id===n.id); db.notes[i] = updated; }
else db.notes.unshift(updated);
save(); closeModal(); render();
});
}

function closeModal() { document.getElementById(“modal-overlay”).classList.remove(“open”); }

// ── Events ────────────────────────────────────────────────────────────────────
document.getElementById(“modal-close”).addEventListener(“click”, closeModal);
document.getElementById(“modal-overlay”).addEventListener(“click”, e => { if(e.target===e.currentTarget) closeModal(); });
document.getElementById(“new-btn”).addEventListener(“click”, () => {
if (state.view === “notes”) openNoteModal(null); else openTaskModal(null);
});
document.getElementById(“search”).addEventListener(“input”, e => { state.search = e.target.value; render(); });

function esc(s) { return String(s||””).replace(/&/g,”&”).replace(/</g,”<”).replace(/>/g,”>”).replace(/”/g,”"”); }

render();
</script>

</body>
</html>
